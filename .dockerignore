# Exclude everything by default, then whitelist only what the Dockerfile needs.
# This keeps the Docker build context small and speeds up `docker build`.

**

# Liberty pre-assembled server
!fhir-server-webapp/target/liberty/wlp/

# Packaged WAR
!fhir-server-webapp/target/fhir-server.war

# Customised configuration overrides
!fhir-server-webapp/src/main/liberty/config/server.xml
!fhir-server-webapp/src/main/liberty/config/config/
!fhir-server-webapp/src/main/liberty/config/config/default/
!fhir-server-webapp/src/main/liberty/config/config/default/fhir-server-config.json
!fhir-server-webapp/src/main/liberty/config/config/default/fhir-server-config.json.tmpl
!fhir-server-webapp/src/main/liberty/config/start.sh

# Schema CLI jar (for DB migrations)
!fhir-persistence-schema/target/fhir-persistence-schema-*-cli.jar

# Dockerfile itself
!Dockerfile
