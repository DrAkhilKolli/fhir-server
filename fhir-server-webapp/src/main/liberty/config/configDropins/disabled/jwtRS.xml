<server description="fhir-server">
    <featureManager>
        <!-- server.xml already enables mpJwt-1.2, but repeating it here keeps this snippet self-contained -->
        <feature>mpJwt-1.2</feature>
    </featureManager>

    <!-- Override the application-bnd binding of the main webapp. The JWT group claim
         must contain FHIRUsers for normal API access and can optionally contain
         FHIRAdmins for admin-only operations.
    -->
    <webApplication contextRoot="fhir-server/api/v4" id="fhir-server-webapp" location="fhir-server.war" name="fhir-server-webapp">
        <application-bnd id="bind">
            <security-role id="users" name="FHIRUsers">
                <group id="usersGroup" name="FHIRUsers"/>
            </security-role>
            <security-role id="admin" name="FHIRAdmins">
                <group id="operationAdminGroup" name="FHIRAdmins"/>
            </security-role>
        </application-bnd>
    </webApplication>

    <!-- Replace the placeholders below with the public Keycloak realm URLs and the
         public FHIR base URL. The JWT iss claim must match issuer exactly, the aud
         claim must match audiences, and the Keycloak group mapper should emit the
         claim name "group" to match groupNameAttribute.
    -->
    <mpJwt id="jwtConsumer"
           jwksUri="http://localhost:8080/realms/smart/protocol/openid-connect/certs"
           issuer="http://localhost:8080/realms/smart"
           audiences="https://localhost:9443/fhir-server/api/v4"
           userNameAttribute="sub"
           groupNameAttribute="group"
           authFilterRef="filter"/>

    <authFilter id="filter">
        <requestUrl urlPattern="/fhir-server" />
        <requestUrl matchType="notContain" urlPattern="/fhir-server/api/v4/metadata" />
        <requestUrl matchType="notContain" urlPattern="/fhir-server/api/v4/.well-known/smart-configuration" />
    </authFilter>
</server>
